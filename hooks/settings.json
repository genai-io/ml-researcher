{
  "_comment": "Methodology hooks for ml-researcher. Merged into <CFG>/settings.json by init.sh; __CFG__ is substituted with the actual config dir (.claude / .gen / .codex). To disable a default after init, remove (or comment out) its entry from the merged <CFG>/settings.json directly.",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "if": "Write(data/raw/**) || Edit(data/raw/**)",
        "hooks": [
          {
            "type": "command",
            "command": "bash __CFG__/hooks/raw_data_guard.sh",
            "statusMessage": "Checking raw data immutability"
          }
        ]
      },
      {
        "matcher": "Read|Bash",
        "if": "Read(data/splits/test/**) || Bash(*data/splits/test*)",
        "hooks": [
          {
            "type": "command",
            "command": "bash __CFG__/hooks/test_set_guard.sh",
            "statusMessage": "Checking test-set lock"
          }
        ]
      },
      {
        "matcher": "exp-run",
        "hooks": [
          {
            "type": "command",
            "command": "bash __CFG__/hooks/preflight.sh",
            "statusMessage": "Running pre-flight checklist"
          }
        ]
      },
      {
        "matcher": "phase-advance",
        "hooks": [
          {
            "type": "command",
            "command": "bash __CFG__/hooks/phase_gate.sh",
            "statusMessage": "Verifying phase advancement requirements"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "exp-run",
        "hooks": [
          {
            "type": "command",
            "command": "bash __CFG__/hooks/trace_append.sh",
            "async": true
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash __CFG__/hooks/expect_mode_banner.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash __CFG__/hooks/stop_resume_check.sh"
          }
        ]
      }
    ]
  }
}
